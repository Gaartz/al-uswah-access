rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - any authenticated user can read; any authenticated user can write
    // (role-based access control is enforced client-side in app.js)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Attendance collection - any authenticated user can read/write
    // (admins need write access for manual attendance)
    match /attendance/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Config collections
    match /config/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /branches/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /menus/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Perizinan (Leave Request) collection
    match /perizinan/{document} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }
    // Pelanggaran (Violation) collection
    match /pelanggaran/{document} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null;
    }
    // Arsip collection
    match /arsip/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    // Slip Gaji collection
    match /slip_gaji/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
  }
}